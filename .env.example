# ===========================================
# ENVIRONMENT CONFIGURATION
# ===========================================
# Set to 'development' for local testing or 'production' for Railway deployment
NODE_ENV=development

# ===========================================
# PRODUCTION CONFIGURATION (Railway)
# ===========================================
# These are used when NODE_ENV=production
# Set these in Railway dashboard for production deployment

PROD_BOT_TOKEN=
PROD_CLIENT_ID=
PROD_GUILD_ID=

# Railway database configuration (use Railway volume path)
PROD_DB_HOST=localhost
PROD_DB_DIALECT=sqlite
PROD_DB_STORAGE=/app/data/database.sqlite

# ===========================================
# DEVELOPMENT/TEST CONFIGURATION (Local Docker)
# ===========================================
# These are used when NODE_ENV=development
# Set these in your local .env file for testing

TEST_BOT_TOKEN=
TEST_CLIENT_ID=
TEST_GUILD_ID=

# Local database configuration (use local data directory)
TEST_DB_HOST=localhost
TEST_DB_DIALECT=sqlite
TEST_DB_STORAGE=./data/database.sqlite

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================
DB_LOGGING=false

# ===========================================
# QUICK START GUIDE
# ===========================================
#
# FOR LOCAL DOCKER DEVELOPMENT:
# 1. Copy this file to .env
# 2. Set NODE_ENV=development
# 3. Fill in TEST_* variables with your test Discord bot credentials
# 4. Run: docker compose up
# 5. Database will be stored in ./data/database.sqlite
#
# FOR RAILWAY PRODUCTION DEPLOYMENT:
# 1. Create a Railway project from this GitHub repo
# 2. Add a volume mounted at /app/data
# 3. Set environment variables in Railway dashboard:
#    - NODE_ENV=production
#    - PROD_BOT_TOKEN=<your_production_bot_token>
#    - PROD_CLIENT_ID=<your_production_client_id>
#    - PROD_GUILD_ID=<your_production_guild_id>
#    - PROD_DB_STORAGE=/app/data/database.sqlite
# 4. Deploy! Commands will deploy automatically on startup.
#
